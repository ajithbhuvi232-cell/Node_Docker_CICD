pipeline {
    agent any
    environment {
        IMAGE_NAME =  'nodeapp:1.0.0'
        DOCKERHUB_CREDENTIALS = 'dockerhub_token'
        DOCKERHUB_REPOSITORY = 'ajithkumar0104/cicd_repo'
    }
    stages {
        stage('checkout') {
            steps {
                git branch: 'main', url:'https://github.com/ajithbhuvi232-cell/Node_Docker_CICD.git'
            }
        }
        stage('build') {
            steps {
                sh "docker build -t ${env.IMAGE_NAME} ."
            }
        }
        stage('push') {
            steps {
                withCredentials([usernamePassword(credentialsId: env.DOCKERHUB_CREDENTIALS, usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_PASSWORD')]) {
                    sh "echo ${DOCKERHUB_PASSWORD} | docker login -u ${DOCKERHUB_USERNAME} --password-stdin"
                    sh "docker tag ${env.IMAGE_NAME} ${env.DOCKERHUB_REPOSITORY}:latest"
                    sh "docker push ${env.DOCKERHUB_REPOSITORY}:latest"
                }
            }
        }
        stage('pull') {
            steps {
                sh "docker pull ${env.DOCKERHUB_REPOSITORY}:latest"
            }
        }
        stage('deploy') {
            steps {
                sh "docker run -d -p 3000:3000 --name nodeappcontainer1 ${env.DOCKERHUB_REPOSITORY}:latest ${env.DOCKERHUB_REPOSITORY}:latest"
            }
        }
    }
}