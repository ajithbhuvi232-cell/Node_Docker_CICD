pipeline {
    agent any
    environment {
        IMAGE_NAME =  'nodeapp:1.0.0'
    }
    stages {
        stage('checkout') {
            steps {
                git branch: 'main', url:'https://github.com/ajithbhuvi232-cell/Node_Docker_CICD.git'
            }
        }
        stage('build') {
            steps {
                sh 'docker build -t ${env.IMAGE_NAME}'
            }
        }
        stage('run') {
            steps {
                sh 'docker run -d -p 3000:3000 ${env.IMAGE_NAME}'
            }
        }
        stage('list') {
            steps {
                sh 'docker images'
            }
        }
    }
}